---
// 功能：一个场景的卡片区块。带标题、副标题、卡片数量、网格布局
// 输入：scene + cards
// 输出：一个 <section>，含 header 与卡片网格
// 依赖：types, Card
// 在项目中的作用：index.astro 用它把 8 个场景拼起来

import type { Scene, Card as CardType } from '../lib/types';
import Card from './Card.astro';

interface Props {
  scene: Scene;
  cards: CardType[];
}

const { scene, cards } = Astro.props;
const accent = `var(--scene-${scene.color_token})`;
const soft = `var(--scene-${scene.color_token}-soft)`;
const isEmpty = cards.length === 0;
---

<section id={`scene-${scene.id}`} class="mb-12 scroll-mt-20">
  <header class="mb-4 flex flex-col gap-1">
    <div class="flex items-baseline gap-3 flex-wrap">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight" style={`color:${accent};`}>
        {scene.icon} {scene.name_zh}
      </h2>
      <span class="text-xs font-sans text-muted">
        {scene.name_en} · {cards.length}/{scene.v2_target} 张
      </span>
    </div>
    <p class="text-sm text-ink-soft max-w-2xl">{scene.blurb}</p>
    <div class="h-[2px] rounded-full" style={`background:${soft};`}></div>
  </header>

  {isEmpty ? (
    <div
      class="rounded-card p-6 text-center text-sm text-muted font-sans border border-dashed"
      style={`border-color:${accent};`}
    >
      🚧 v2 即将上线 · 目标 {scene.v2_target} 张
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map((c) => <Card card={c} />)}
    </div>
  )}
</section>
