---
// 功能：路牌识字卡片。结构 = 真实招牌照片 + attribution + 招牌文字（俄语/乌兹别克语
//       拉丁/西里尔多语并存）+ 中文 + context + local_note
// 输入：sign prop (Sign 类型)，由 /signs 页面从 signs.json 派发
// 输出：一个 <article> 带 category 主题色左边框
// 依赖：lib/types
// 在项目中的作用：/signs 路牌识字页的视觉单元。与 Card / UzbekCard 平级。
//             不进 SRS、不带音频、所有信息平铺不折叠——出发前混眼熟用。

import type { Sign } from '../lib/types';

interface Props {
  sign: Sign;
}

const { sign } = Astro.props;

// category → 现有 scene CSS 变量（复用配色，不引入新 token）
const CATEGORY_COLOR_VAR: Record<Sign['category'], string> = {
  airport:    '--scene-transport',   // 蓝 —— 出行
  street:     '--scene-transport',   // 蓝 —— 同属城市出行
  market:     '--scene-shopping',    // 橙 —— 巴扎与购物
  restaurant: '--scene-food',        // 红 —— 餐饮
  public:     '--scene-emergency',   // 灰 —— 公共应急标识
};
const accentVar = CATEGORY_COLOR_VAR[sign.category];

// 把 attribution.license 简化显示（去 -4.0 / -2.0 等版本号也仍可读）
const licenseShort = sign.image.attribution.license;
---

<article
  class="sign-card card-surface relative overflow-hidden flex flex-col"
  style={`border-left-color: var(${accentVar});`}
>
  {/* —— 真实路牌照片 —— */}
  <div class="sign-photo">
    <img
      src={sign.image.src}
      alt={sign.image.alt}
      loading="lazy"
      decoding="async"
    />
    {/* attribution 浮在右下角，半透明黑底 */}
    <a
      href={sign.image.attribution.source_url}
      target="_blank"
      rel="noopener noreferrer"
      class="sign-attribution"
      title={`${sign.image.attribution.author} · ${licenseShort}`}
    >
      © {sign.image.attribution.author} · {licenseShort}
    </a>
  </div>

  {/* —— 招牌文字 —— */}
  <div class="px-4 md:px-5 pt-4 flex flex-col gap-1">
    {sign.ru && (
      <p class="sign-ru cyr text-2xl md:text-3xl font-bold text-ink leading-snug">
        {sign.ru}
      </p>
    )}
    {(sign.uz_latin || sign.uz_cyrillic) && (
      <p class="sign-uz text-base md:text-lg text-ink-soft leading-snug">
        <span class="sign-uz-label">UZ</span>
        {sign.uz_latin}
        {sign.uz_latin && sign.uz_cyrillic && <span class="sign-uz-sep"> · </span>}
        {sign.uz_cyrillic}
      </p>
    )}
    {sign.ru_translit && (
      <p class="trans">{sign.ru_translit}</p>
    )}
    <p class="text-base md:text-lg text-ink-soft leading-snug">{sign.chinese}</p>
    {sign.literal && (
      <p class="text-[0.7rem] text-muted italic mt-0.5">{sign.literal}</p>
    )}
  </div>

  {/* —— 上下文 —— */}
  <div class="px-4 md:px-5 py-4 flex flex-col gap-2">
    {sign.location_hint && (
      <p class="sign-location text-xs leading-snug">
        <span class="sign-location-icon" aria-hidden="true">📍</span>
        <span class="sign-location-text">{sign.location_hint}</span>
      </p>
    )}
    <p class="text-xs text-ink-soft leading-relaxed">
      <span class="text-[0.6rem] font-sans uppercase tracking-widest text-muted mr-2">
        何时看到
      </span>
      {sign.context}
    </p>
    {sign.local_note && (
      <p class="text-xs text-muted leading-relaxed">
        <span class="text-[0.6rem] font-sans uppercase tracking-widest text-muted mr-2">
          当地注
        </span>
        {sign.local_note}
      </p>
    )}
  </div>
</article>

<style is:global>
  /* 路牌卡片 —— 与 .uzbek-card 同一族，但更注重图片呈现 */
  .sign-card {
    border-left-width: 4px;
    border-left-style: solid;
    padding: 0;        /* 图片要顶住边框 */
  }

  .sign-photo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--paper-soft);
    overflow: hidden;
  }
  .sign-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sign-attribution {
    position: absolute;
    right: 0.4rem;
    bottom: 0.4rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.6rem;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    text-decoration: none;
    max-width: calc(100% - 0.8rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: background 140ms ease;
  }
  .sign-attribution:hover {
    background: rgba(0, 0, 0, 0.78);
  }

  /* 招牌俄语主字——比 Card 的 .cyr 略大、更"招牌感" */
  .sign-ru {
    letter-spacing: 0.005em;
  }

  /* UZ 拉丁/西里尔副显 */
  .sign-uz {
    font-family: 'PT Serif', 'Noto Serif SC', Georgia, serif;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .sign-uz-label {
    display: inline-block;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: var(--paper-soft);
    flex-shrink: 0;
  }
  .sign-uz-sep {
    color: var(--muted);
  }

  /* 拍摄地点 hint —— 给「图寻」味儿，独立小行，淡背景 */
  .sign-location {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.3rem 0.55rem;
    border-radius: 6px;
    background: var(--paper-soft);
    color: var(--ink-soft);
    align-self: flex-start;
    max-width: 100%;
  }
  .sign-location-icon {
    flex-shrink: 0;
    font-size: 0.85rem;
    line-height: 1;
  }
  .sign-location-text {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.7rem;
    line-height: 1.35;
    letter-spacing: 0.01em;
  }
</style>
