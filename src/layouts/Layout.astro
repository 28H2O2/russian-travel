---
// 功能：全站页面外壳。统一 <head>、字体 preconnect、PWA meta、安全区域、最外层布局
// 输入：title / description prop + slot 内容
// 输出：完整 HTML 文档
// 依赖：src/styles/global.css
// 在项目中的作用：所有 pages/*.astro 的母版

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '俄语生存包 · 给乌兹别克斯坦旅行者',
  description = '~250 张俄语生存短语卡，含发音、对方可能的回话、当地注脚。离线可用。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf5ec" />
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* PWA: iOS 主屏图标 + 全屏模式 + 启动屏配色 */}
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="РусUZ" />
    <meta name="mobile-web-app-capable" content="yes" />
    {/* manifest 由 @vite-pwa/astro 自动注入 <link rel="manifest" ...> */}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class="safe-pt safe-pb">
    <slot />
  </body>
</html>
