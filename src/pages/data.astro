---
// 功能：数据页。显示进度统计、导出 JSON、导入 JSON、清空进度
// 输入：src/data/cards.json（用于知道总卡数 + 新卡基线）
// 输出：单页 GUI（所有交互在客户端、通过 lib/progress-export 操作 IndexedDB）
// 如何运行：astro dev → http://localhost:4321/data
// 依赖：Layout, lib/data, 客户端 lib/srs / lib/db / lib/progress-export
// 在项目中的作用：用户的逃生口——备份、跨设备同步、重置

import Layout from '../layouts/Layout.astro';
import { getCards } from '../lib/data';

const cards = getCards();
const cardIds = JSON.stringify(cards.map((c) => c.id));
---

<Layout title="数据 · 俄语生存包" description="导入导出进度、查看练习统计">
  <main class="max-w-2xl mx-auto px-4 pt-6 pb-16">
    <header class="flex items-center justify-between mb-6">
      <a
        href="/"
        class="text-sm font-sans text-muted hover:text-ink-soft transition-colors inline-flex items-center gap-1"
      >
        ← 返回
      </a>
      <h1 class="font-serif text-xl text-ink">数据</h1>
      <a
        href="/practice"
        class="text-sm font-sans text-muted hover:text-ink-soft transition-colors"
      >
        练习
      </a>
    </header>

    {/* 统计 */}
    <section class="card-surface p-5 mb-4">
      <h2 class="font-serif text-lg text-ink mb-3">练习统计</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        <div>
          <p class="text-[0.65rem] font-sans uppercase tracking-widest text-muted">未学</p>
          <p class="font-serif text-2xl text-ink" data-stat="new">—</p>
        </div>
        <div>
          <p class="text-[0.65rem] font-sans uppercase tracking-widest text-muted">到期</p>
          <p class="font-serif text-2xl text-ink" style="color: var(--accent);" data-stat="due">—</p>
        </div>
        <div>
          <p class="text-[0.65rem] font-sans uppercase tracking-widest text-muted">学习中</p>
          <p class="font-serif text-2xl text-ink" data-stat="later">—</p>
        </div>
        <div>
          <p class="text-[0.65rem] font-sans uppercase tracking-widest text-muted">已掌握</p>
          <p class="font-serif text-2xl text-ink" style="color: var(--scene-money);" data-stat="mature">—</p>
        </div>
      </div>
      <p class="text-xs text-muted mt-3" data-stat-extra>—</p>
    </section>

    {/* 导出 */}
    <section class="card-surface p-5 mb-4">
      <h2 class="font-serif text-lg text-ink mb-2">导出进度</h2>
      <p class="text-xs text-muted mb-4 leading-relaxed">
        下载一个 JSON 文件，包含你所有的 SRS 进度。换手机、清缓存、重装前先备份。
      </p>
      <button type="button" data-action="export" class="practice-btn-primary w-full">
        ⤓ 下载 JSON
      </button>
    </section>

    {/* 导入 */}
    <section class="card-surface p-5 mb-4">
      <h2 class="font-serif text-lg text-ink mb-2">导入进度</h2>
      <p class="text-xs text-muted mb-4 leading-relaxed">
        从备份 JSON 恢复。<strong class="text-ink-soft">合并</strong>：保留较新的记录；
        <strong class="text-ink-soft">替换</strong>：清空当前后写入。
      </p>
      <input
        type="file"
        accept="application/json,.json"
        id="import-file"
        class="block w-full text-sm text-ink-soft mb-3
               file:mr-3 file:py-2 file:px-4 file:rounded-md file:border-0
               file:text-sm file:font-medium
               file:bg-stone-100 file:text-ink-soft hover:file:bg-stone-200"
      />
      <div class="grid grid-cols-2 gap-2">
        <button type="button" data-action="import-merge" class="practice-btn-secondary">
          合并导入
        </button>
        <button type="button" data-action="import-replace" class="practice-btn-secondary" style="color: #7a2e26;">
          替换导入
        </button>
      </div>
    </section>

    {/* 危险区 */}
    <section class="card-surface p-5 border-l-4" style="border-left-color: var(--scene-food);">
      <h2 class="font-serif text-lg text-ink mb-2">危险区</h2>
      <p class="text-xs text-muted mb-4 leading-relaxed">
        清空所有进度 —— 不可撤销。建议先导出备份。
      </p>
      <button
        type="button"
        data-action="wipe"
        class="practice-btn-secondary w-full"
        style="color: #7a2e26;"
      >
        清空所有进度
      </button>
    </section>

    {/* 反馈区 */}
    <div
      id="data-toast"
      class="fixed left-1/2 -translate-x-1/2 bottom-6 px-4 py-2 rounded-full text-sm font-sans z-30 transition-all"
      style="background: var(--ink); color: var(--paper); opacity: 0; transform: translate(-50%, 10px);"
    ></div>
  </main>

  <script is:inline type="application/json" id="data-card-ids" set:html={cardIds}></script>

  <script>
    import {
      getAllProgress,
      wipeEverything,
      ensureInstalled,
      getMeta,
      META_KEYS,
    } from '../lib/db';
    import { bucketize, dueLabel } from '../lib/srs';
    import type { CardProgress } from '../lib/srs';
    import {
      exportAndDownload,
      importProgress,
      ImportError,
      type ImportMode,
    } from '../lib/progress-export';

    const idsEl = document.getElementById('data-card-ids');
    const ALL_CARD_IDS: string[] = JSON.parse(idsEl?.textContent || '[]');

    // ---------- 提示条 ----------
    let toastTimer: number | null = null;
    function toast(msg: string, kind: 'ok' | 'error' = 'ok') {
      const t = document.getElementById('data-toast') as HTMLElement | null;
      if (!t) return;
      t.textContent = msg;
      t.style.background = kind === 'error' ? '#7a2e26' : 'var(--ink)';
      t.style.opacity = '1';
      t.style.transform = 'translate(-50%, 0)';
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        t.style.opacity = '0';
        t.style.transform = 'translate(-50%, 10px)';
      }, 2400);
    }

    // ---------- 统计渲染 ----------
    async function refreshStats() {
      try {
        await ensureInstalled();
        const all = await getAllProgress();
        const stats = bucketize(ALL_CARD_IDS, all, Date.now());
        document.querySelector('[data-stat="new"]')!.textContent = String(stats.new);
        document.querySelector('[data-stat="due"]')!.textContent = String(stats.due);
        document.querySelector('[data-stat="later"]')!.textContent = String(stats.later);
        document.querySelector('[data-stat="mature"]')!.textContent = String(stats.mature);

        const lastSession = await getMeta<number>(META_KEYS.lastSessionAt);
        const reviewedCount = all.filter((p) => p.total_reviews > 0).length;
        let extra = `总卡 ${stats.total} 张 · 练过 ${reviewedCount} 张`;
        if (lastSession) {
          const diff = Date.now() - lastSession;
          const days = Math.floor(diff / (24 * 60 * 60 * 1000));
          const hours = Math.floor(diff / (60 * 60 * 1000));
          extra += ` · 上次练习：${
            days >= 1 ? `${days} 天前` : hours >= 1 ? `${hours} 小时前` : '不久前'
          }`;
        }
        // 下次到期
        const nextDue = all
          .filter((p) => p.total_reviews > 0 && p.due > Date.now())
          .map((p) => p.due)
          .sort((a, b) => a - b)[0];
        if (nextDue) {
          extra += ` · 下次到期：${dueLabel({ due: nextDue } as CardProgress, Date.now())}`;
        }
        const extraEl = document.querySelector<HTMLElement>('[data-stat-extra]');
        if (extraEl) extraEl.textContent = extra;
      } catch (e) {
        console.error(e);
      }
    }

    // ---------- 导出 ----------
    async function handleExport() {
      try {
        const bundle = await exportAndDownload();
        toast(`已导出 ${bundle.card_count} 条进度`);
      } catch (e) {
        toast('导出失败：' + (e as Error).message, 'error');
      }
    }

    // ---------- 导入 ----------
    async function handleImport(mode: ImportMode) {
      const fileInput = document.getElementById('import-file') as HTMLInputElement;
      const file = fileInput.files?.[0];
      if (!file) {
        toast('请先选文件', 'error');
        return;
      }
      if (mode === 'replace') {
        if (!confirm('替换导入会清空当前进度。继续？')) return;
      }
      try {
        const text = await file.text();
        const res = await importProgress(text, mode);
        toast(`已导入 ${res.imported} 条（跳过 ${res.skipped}）`);
        await refreshStats();
      } catch (e) {
        if (e instanceof ImportError) {
          toast(e.message, 'error');
        } else {
          toast('导入失败：' + (e as Error).message, 'error');
        }
      }
    }

    // ---------- 清空 ----------
    async function handleWipe() {
      if (!confirm('清空所有进度。不可撤销。确定？')) return;
      if (!confirm('再确认一次：所有 SRS 进度会被删除。')) return;
      try {
        await wipeEverything();
        toast('已清空');
        await refreshStats();
      } catch (e) {
        toast('清空失败：' + (e as Error).message, 'error');
      }
    }

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-action="export"]')) handleExport();
      else if (target.closest('[data-action="import-merge"]')) handleImport('merge');
      else if (target.closest('[data-action="import-replace"]')) handleImport('replace');
      else if (target.closest('[data-action="wipe"]')) handleWipe();
    });

    refreshStats();
  </script>
</Layout>
