---
// 功能：主页。顶部品牌 + 场景跳转条 + 必备卡便捷柜 + 8 个场景区块
// 输入：src/data/cards.json + src/data/scenes.json
// 输出：单页 HTML（手机优先布局）
// 依赖：Layout, EssentialBar, SceneSection, lib/data
// 在项目中的作用：v1 唯一的页面

import Layout from '../layouts/Layout.astro';
import EssentialBar from '../components/EssentialBar.astro';
import SceneSection from '../components/SceneSection.astro';
import { getScenes, getCardsByScene, getEssentialCards, getCards } from '../lib/data';

const scenes = getScenes();
const essentials = getEssentialCards(10);
const totalCards = getCards().length;
const v2Total = scenes.reduce((sum, s) => sum + s.v2_target, 0);
---

<Layout>
  {/* 顶部品牌 */}
  <header class="max-w-5xl mx-auto px-4 pt-10 pb-6 md:pt-16 md:pb-10 text-center">
    <p class="text-xs font-sans uppercase tracking-[0.3em] text-muted mb-2">
      A Survival Kit for Travelers · 2026
    </p>
    <h1 class="font-serif text-4xl md:text-6xl font-bold text-ink leading-tight">
      <span class="text-accent">Русский</span> для Узбекистана
    </h1>
    <p class="mt-3 text-sm md:text-base text-ink-soft font-serif italic">
      俄语生存包 · 给乌兹别克斯坦旅行者
    </p>
    <p class="mt-4 text-xs md:text-sm text-muted max-w-2xl mx-auto leading-relaxed">
      {totalCards} / {v2Total} 张短语卡 · 含发音、对方可能的回话、可替换槽、Uzbekistan 当地注脚 · 离线可用 · 无注册无收集
    </p>
  </header>

  {/* 场景跳转条 — 粘性 */}
  <nav
    class="sticky top-0 z-20 bg-paper/95 backdrop-blur-sm border-b border-card-border"
    aria-label="场景跳转"
  >
    <div class="max-w-5xl mx-auto px-3 py-2 overflow-x-auto">
      <ul class="flex gap-1.5 whitespace-nowrap text-sm font-sans">
        <li>
          <a
            href="#essential-bar"
            class="inline-flex items-center px-3 py-1.5 rounded-full bg-stone-100 text-ink-soft hover:bg-stone-200 transition-colors"
          >
            ⭐ 必备
          </a>
        </li>
        {scenes.map((s) => {
          const count = getCardsByScene(s.id).length;
          const inactive = count === 0;
          return (
            <li>
              <a
                href={`#scene-${s.id}`}
                class={`inline-flex items-center gap-1 px-3 py-1.5 rounded-full transition-colors ${
                  inactive
                    ? 'bg-stone-50 text-muted hover:bg-stone-100'
                    : 'bg-stone-100 text-ink-soft hover:bg-stone-200'
                }`}
                style={`border-bottom: 2px solid var(--scene-${s.color_token});`}
              >
                <span>{s.icon}</span>
                <span>{s.name_zh}</span>
                <span class="text-[0.65rem] text-muted">{count}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>

  {/* 主内容 */}
  <main class="max-w-5xl mx-auto px-4 pt-8">
    <EssentialBar cards={essentials} />

    {scenes.map((s) => (
      <SceneSection scene={s} cards={getCardsByScene(s.id)} />
    ))}
  </main>

  {/* 底部说明 */}
  <footer class="max-w-5xl mx-auto px-4 py-12 text-xs font-sans text-muted text-center space-y-2">
    <p>
      ⚠ 当前阶段卡片由 LLM 生成、未经俄语母语者审校。现场使用后欢迎在 GitHub 反馈。
    </p>
    <p>
      无注册、不收集任何信息 · 设计灵感来自
      <a
        href="https://ogden.munch.love"
        class="underline hover:text-ink-soft"
        target="_blank"
        rel="noopener"
      >ogden.munch.love</a>
    </p>
  </footer>
</Layout>
