---
// 功能：主页。顶部品牌 + 场景跳转条 + 必备卡便捷柜 + 8 个场景区块
// 输入：src/data/cards.json + src/data/scenes.json
// 输出：单页 HTML（手机优先布局）
// 依赖：Layout, EssentialBar, SceneSection, lib/data
// 在项目中的作用：v1 唯一的页面

import Layout from '../layouts/Layout.astro';
import EssentialBar from '../components/EssentialBar.astro';
import SceneSection from '../components/SceneSection.astro';
import { getScenes, getCardsByScene, getEssentialCards, getCards } from '../lib/data';
import uzbekJson from '../data/uzbek.json';
import signsJson from '../data/signs.json';

const scenes = getScenes();
const essentials = getEssentialCards(10);
const totalCards = getCards().length;
const v2Total = scenes.reduce((sum, s) => sum + s.v2_target, 0);
const uzbekCount = (uzbekJson as unknown[]).length;
const signsCount = (signsJson as unknown[]).length;
---

<Layout>
  {/* 右上角工具条：手机 emoji-only、≥sm 才显文字 */}
  <div class="fixed top-3 right-3 z-30 flex gap-1.5 safe-pt">
    <a
      href="/signs"
      class="home-tool-link home-tool-signs"
      aria-label="路牌识字"
    >
      <span class="home-tool-icon">🪧</span>
      <span class="home-tool-text">路牌</span>
    </a>
    <a
      href="/uzbek"
      class="home-tool-link home-tool-uzbek"
      aria-label="乌兹别克语彩蛋"
    >
      <span class="home-tool-icon">🇺🇿</span>
      <span class="home-tool-text">彩蛋</span>
    </a>
    <a
      href="/practice"
      class="home-tool-link"
      aria-label="进入练习"
    >
      <span class="home-tool-icon">📝</span>
      <span class="home-tool-text">练习</span>
    </a>
    <a
      href="/data"
      class="home-tool-link"
      aria-label="数据与备份"
    >
      <span class="home-tool-icon">💾</span>
      <span class="home-tool-text">数据</span>
    </a>
  </div>

  {/* 顶部品牌 */}
  <header class="max-w-5xl mx-auto px-4 pt-10 pb-6 md:pt-16 md:pb-10 text-center">
    <p class="text-xs font-sans uppercase tracking-[0.3em] text-muted mb-2">
      A Survival Kit for Travelers · 2026
    </p>
    <h1 class="font-serif text-4xl md:text-6xl font-bold text-ink leading-tight">
      <span class="text-accent">Русский</span> для Узбекистана
    </h1>
    <p class="mt-3 text-sm md:text-base text-ink-soft font-serif italic">
      俄语生存包 · 给乌兹别克斯坦旅行者
    </p>
    <p class="mt-4 text-xs md:text-sm text-muted max-w-2xl mx-auto leading-relaxed">
      {totalCards} / {v2Total} 张俄语短语卡 ·
      <a href="/uzbek" class="underline hover:text-accent">{uzbekCount} 句乌兹别克语彩蛋 🇺🇿</a> ·
      <a href="/signs" class="underline hover:text-accent">{signsCount} 张真实路牌 🪧</a><br />
      含发音、对方可能的回话、可替换槽、Uzbekistan 当地注脚 · 离线可用 · 无注册无收集
    </p>
  </header>

  {/* 场景跳转条 — 粘性 */}
  <nav
    class="sticky top-0 z-20 bg-paper/95 backdrop-blur-sm border-b border-card-border"
    aria-label="场景跳转"
  >
    <div class="max-w-5xl mx-auto px-3 py-2 overflow-x-auto">
      <ul class="flex gap-1.5 whitespace-nowrap text-sm font-sans">
        <li>
          <a
            href="#essential-bar"
            class="inline-flex items-center px-3 py-1.5 rounded-full bg-stone-100 text-ink-soft hover:bg-stone-200 transition-colors"
          >
            ⭐ 必备
          </a>
        </li>
        {scenes.map((s) => {
          const count = getCardsByScene(s.id).length;
          const inactive = count === 0;
          return (
            <li>
              <a
                href={`#scene-${s.id}`}
                class={`inline-flex items-center gap-1 px-3 py-1.5 rounded-full transition-colors ${
                  inactive
                    ? 'bg-stone-50 text-muted hover:bg-stone-100'
                    : 'bg-stone-100 text-ink-soft hover:bg-stone-200'
                }`}
                style={`border-bottom: 2px solid var(--scene-${s.color_token});`}
              >
                <span>{s.icon}</span>
                <span>{s.name_zh}</span>
                <span class="text-[0.65rem] text-muted">{count}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>

  {/* 主内容 */}
  <main class="max-w-5xl mx-auto px-4 pt-8">
    <EssentialBar cards={essentials} />

    {scenes.map((s) => (
      <SceneSection scene={s} cards={getCardsByScene(s.id)} />
    ))}
  </main>

  {/* 底部说明 */}
  <footer class="max-w-5xl mx-auto px-4 py-12 pb-28 text-xs font-sans text-muted text-center space-y-2">
    <p>
      ⚠ 当前阶段卡片由 LLM 生成、未经俄语母语者审校。现场使用后欢迎在 GitHub 反馈。
    </p>
    <p>
      无注册、不收集任何信息 · 设计灵感来自
      <a
        href="https://ogden.munch.love"
        class="underline hover:text-ink-soft"
        target="_blank"
        rel="noopener"
      >ogden.munch.love</a>
    </p>
  </footer>

  {/* 浮动入口：今日 N 张待练；iPhone 安全区做让位避开 home indicator */}
  <a
    href="/practice"
    id="home-practice-fab"
    class="fixed right-4 z-30 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full
           text-sm font-sans font-semibold shadow-lg transition-all opacity-0 translate-y-2 pointer-events-none"
    style="background: var(--ink); color: var(--paper); min-height: 48px; bottom: max(1rem, env(safe-area-inset-bottom));"
    aria-label="进入练习"
    hidden
  >
    <span>▶</span>
    <span data-fab-label>开始练习</span>
  </a>

  <script is:inline type="application/json" id="home-card-ids" set:html={JSON.stringify(getCards().map((c) => c.id))}></script>
  <script>
    import { getAllProgress, ensureInstalled } from '../lib/db';
    import { bucketize } from '../lib/srs';

    const fab = document.getElementById('home-practice-fab');
    const idsEl = document.getElementById('home-card-ids');
    if (fab && idsEl) {
      const ids: string[] = JSON.parse(idsEl.textContent || '[]');
      (async () => {
        try {
          await ensureInstalled();
          const all = await getAllProgress();
          const stats = bucketize(ids, all, Date.now());
          const label = fab.querySelector<HTMLElement>('[data-fab-label]');
          if (label) {
            if (stats.due > 0) {
              label.textContent = `今日 ${stats.due} 张待复习`;
            } else if (all.length === 0) {
              label.textContent = '开始练习';
            } else {
              label.textContent = '继续练习';
            }
          }
          fab.hidden = false;
          // 入场动画
          requestAnimationFrame(() => {
            fab.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
            fab.classList.add('opacity-100', 'translate-y-0');
          });
        } catch (e) {
          // 无 IndexedDB / 出错 → 仍然显示一个普通入口
          fab.hidden = false;
          fab.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        }
      })();
    }
  </script>
</Layout>

<style is:global>
  /* 主页右上角小工具链接 */
  .home-tool-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    /* mobile：紧凑圆形 tap target；保证 ≥ 36px 高、约 36px 宽 */
    min-width: 38px;
    min-height: 38px;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 250, 240, 0.9);
    backdrop-filter: blur(6px);
    border: 1px solid var(--card-border);
    color: var(--ink-soft);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1;
    transition: background 140ms ease, color 140ms ease;
  }
  .home-tool-icon {
    font-size: 1.05rem;
    line-height: 1;
  }
  .home-tool-text {
    /* mobile：隐藏文字、纯 emoji；≥ sm (640px) 显文字 */
    display: none;
  }
  @media (min-width: 640px) {
    .home-tool-link {
      padding: 0.4rem 0.85rem;
    }
    .home-tool-text {
      display: inline;
    }
  }
  .home-tool-link:hover {
    background: var(--paper-soft);
    color: var(--ink);
  }
  /* 彩蛋链接：用 UZ 国旗 teal */
  .home-tool-uzbek {
    background: var(--scene-uzbek-soft);
    border-color: var(--scene-uzbek);
    color: var(--scene-uzbek);
    font-weight: 600;
  }
  .home-tool-uzbek:hover {
    background: var(--scene-uzbek);
    color: var(--paper);
  }
</style>
